Dim kmRodados As Double
Dim litrosGastos As Double
Dim mediaConsumo As Double

Print "=== CALCULO DE CONSUMO DO VEICULO ==="

Print "Informe a distancia percorrida em km:"
Input kmRodados

Print "Informe quantos litros de combustivel foram usados:"
Input litrosGastos

mediaConsumo = kmRodados / litrosGastos

Print "Consumo medio do veiculo: "; mediaConsumo; " km/l"

Sleep
